{
  "name": "@audebase/kernel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "aude": "./src/cli.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "start": "tsx src/cli.ts start",
    "build": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@audebase/manifest-engine": "workspace:*",
    "@audebase/migration-engine": "workspace:*",
    "@audebase/plugin-core": "workspace:*",
    "@audebase/plugin-framework": "workspace:*",
    "@audebase/rbac": "workspace:*",
    "@audebase/audit": "workspace:*",
    "@audebase/i18n": "workspace:*",
    "@audebase/event-bus": "workspace:*",
    "@audebase/plugin-communication": "workspace:*",
    "@audebase/cron": "workspace:*",
    "@audebase/shared-types": "workspace:*",
    "@audebase/websocket": "workspace:*",
    "@fastify/rate-limit": "^11.1.0",
    "drizzle-orm": "^0.45.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.13.0",
    "pino": "^9.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "tsx": "^4.19.0"
  }
}
