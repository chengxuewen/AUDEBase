# AUDEBase — Local development environment variables
# Copy to .env and adjust as needed. .env is gitignored.

# Database
DATABASE_URL=postgresql://aude:aude@localhost:5432/audebase

# Security: must be >= 32 characters (NocoBase CVE-2025-13877)
AUDE_JWT_SECRET=change-me-to-a-random-64-character-string-minimum-32-chars

# Redis
REDIS_URL=redis://localhost:6379