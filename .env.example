# AUDEBase — Local development environment variables
# Copy to .env and adjust as needed. .env is gitignored.

# When running inside Docker (docker compose): use 'postgres' and 'redis' hostnames.
# When running locally without Docker: use 'localhost' instead.

# Database (postgres service in docker compose)
DATABASE_URL=postgresql://aude:aude@postgres:5432/audebase

# Security: must be >= 32 characters (NocoBase CVE-2025-13877)
AUDE_JWT_SECRET=b64d5054d291db81e8f6678e89608c0fc6aa3c8d19f8f6708f6b7e0c28e5dad5

# Redis (redis service in docker compose)
REDIS_URL=redis://redis:6379

# Logging
AUDE_LOG_LEVEL=info
AUDE_LOG_PRETTY=false
